generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // 用于邮箱+密码登录
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  workspaces      UserWorkspace[]
  subscription    Subscription?
  paymentOrders   PaymentOrder[]
  backgroundJobs  BackgroundJob[]
  collabRoomsHosted CollaborationRoom[] @relation("CollabRoomHost")
  collabMemberships CollaborationMember[]
  pluginPublishReviews PluginPublishReview[]
}

// Plugin publish manual review queue (v1.2.8 F3)
model PluginPublishReview {
  id           String   @id @default(cuid())
  reviewId     String   @unique
  userId       String
  pluginId     String
  version      String
  manifestHash String
  status       String   @default("pending")
  submittedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt])
}

// 支付宝 / 微信 一次性订阅订单
model PaymentOrder {
  id          String    @id @default(cuid())
  userId      String
  planName    String
  channel     String // alipay | wechat
  outTradeNo  String    @unique
  amountCents Int
  currency    String    @default("CNY")
  status      String    @default("pending") // pending | paid | failed | closed
  tradeNo     String?
  createdAt   DateTime  @default(now())
  paidAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 用户工作区数据（云同步）
model UserWorkspace {
  id        String   @id @default(cuid())
  userId    String
  name      String
  files     String   @db.Text // JSON 序列化文件列表
  settings  String?  @db.Text // JSON 序列化设置
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

// 订阅计划
model Plan {
  id          String   @id @default(cuid())
  name        String   @unique // free, pro, enterprise
  displayName String
  description String?
  price       Float // 月费价格
  currency    String   @default("USD")
  features    String   @db.Text // JSON 序列化功能列表
  limits      String   @db.Text // JSON 序列化限制配置
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

// 用户订阅
model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  planId               String
  status               String // active, canceled, past_due, unpaid
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
}

// 后台 Agent 任务（v1.1.2）
model BackgroundJob {
  id         String    @id @default(cuid())
  userId     String
  status     String    @default("queued") // queued | running | succeeded | failed | cancelled
  repoKey    String?
  prompt     String    @db.Text
  progress   Json?
  result     Json?
  error      String?
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
}

// 协作房间（v1.1.3 路线 A）
model CollaborationRoom {
  id        String   @id @default(cuid())
  code      String   @unique
  hostId    String
  name      String?
  status    String   @default("open") // open | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host    User                  @relation("CollabRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  members CollaborationMember[]

  @@index([hostId])
}

model CollaborationMember {
  id       String    @id @default(cuid())
  roomId   String
  userId   String
  role     String    @default("editor") // host | editor | viewer
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  room CollaborationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

// AI 使用量记录
model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  type      String // ai_request, storage, etc.
  amount    Int // 使用数量
  createdAt DateTime @default(now())

  @@index([userId, type, createdAt])
}
