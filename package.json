    "@prisma/client": "^7.8.0",
    "@types/jszip": "^3.4.0",
    "@webcontainer/api": "^1.6.4",
    "bcryptjs": "^3.0.3",
    "fuse.js": "^7.3.0",
    "idb": "^8.0.3",
    "isomorphic-git": "^1.37.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "monaco-editor": "^0.45.0",
    "nodemailer": "^7.0.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^14.0.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
