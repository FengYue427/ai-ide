{
  "name": "ai-ide",
  "version": "1.5.9",
  "description": "开源 AI 原生轻量 IDE",
  "author": "AI IDE",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx scripts/local-dev-server.ts",
    "dev:stack": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "seed:plugin-review": "node scripts/seed-plugin-review.mjs",
    "dev:stack:collab": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"vite --mode collab-e2e\"",
    "dev:full": "npx vercel dev",
    "postinstall": "prisma generate",
    "build": "node scripts/ensure-env-production.mjs && prisma generate && tsc && vite build",
    "copy:website": "node scripts/copy-website.mjs",
    "build:api": "node scripts/build-api.mjs",
    "build:deploy": "node scripts/migrate-if-db.mjs && npm run build:api && npm run build && npm run copy:website",
    "build:prod": "node scripts/ensure-env-production.mjs && prisma generate && tsc && vite build --mode production",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "deploy": "npx vercel --prod",
    "test": "prisma generate && tsc --noEmit && npm run build:deploy",
    "test:unit": "vitest run",
    "i18n:ja-bulk": "node scripts/build-ja-phase2-bulk.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:integration": "node scripts/integration-api.mjs",
    "test:integration:local": "node scripts/run-integration-local.mjs",
    "test:integration:offline": "node scripts/integration-api-offline.mjs",
    "wait:api": "node scripts/wait-for-http.mjs http://127.0.0.1:3001/api/auth/session",
    "test:all": "npm test && npm run test:unit && npm run test:smoke",
    "test:local": "tsc --noEmit && npm run test:unit",
    "test:api:local": "npm run wait:api && npm run test:integration:offline",
    "test:e2e": "playwright test --project=ui",
    "test:e2e:local": "npm run build && playwright test --project=ui",
    "test:e2e:stack": "node scripts/run-e2e-stack.mjs",
    "test:e2e:collab": "node scripts/run-e2e-collab.mjs",
    "test:e2e:install": "playwright install chromium",
    "verify:env": "node scripts/verify-env.mjs",
    "verify:env:prod": "node scripts/verify-env.mjs --production",
    "verify:env:v15": "node scripts/verify-env.mjs --production --v15-production",
    "verify:stripe:prices": "tsx scripts/verify-stripe-prices.ts",
    "verify:alipay:prices": "tsx scripts/verify-alipay-prices.ts",
    "verify:release:gates": "node scripts/verify-release-gates.mjs",
    "predeploy:check": "npm run test:local && node scripts/verify-env.mjs",
    "check:release": "npm run test:local && node scripts/verify-env.mjs --production",
    "check:release:billing": "npm run test:local && node scripts/verify-env.mjs --production --require-cn-billing",
    "check:release:d3": "npm run test:local && node scripts/verify-env.mjs --production --require-cn-billing --d3-ga",
    "d3:preflight": "node scripts/d3-ga-preflight.mjs",
    "s0:gate": "npm run test:local && node scripts/check-skeleton.mjs --skip-tests && node scripts/verify-env.mjs --production",
    "check:skeleton": "node scripts/check-skeleton.mjs",
    "rc:preflight": "node scripts/rc-preflight.mjs",
    "billing:preflight": "node scripts/billing-cn-preflight.mjs",
    "billing:alipay-probe": "tsx scripts/alipay-sandbox-probe.ts",
    "billing:wechat-probe": "tsx scripts/wechat-sandbox-probe.ts",
    "billing:reconcile": "tsx scripts/reconcile-alipay-order.ts",
    "billing:expire": "tsx scripts/billing-expire-subscriptions.ts",
    "billing:verify-cron": "node scripts/verify-cron-expire.mjs",
    "jobs:process": "tsx scripts/jobs-process.ts",
    "jobs:verify-cron": "node scripts/verify-cron-jobs.mjs",
    "billing:reconcile-alipay": "tsx scripts/reconcile-alipay-order.ts",
    "tunnel:api": "node scripts/tunnel-api.mjs",
    "payment:notify-urls": "node scripts/payment-notify-urls.mjs",
    "prod:db": "node scripts/prod-db-setup.mjs",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:neon": "npm run db:check && npm run prod:db",
    "smoke:production": "node scripts/smoke-production.mjs",
    "smoke:report": "node scripts/smoke-report.mjs https://ai-ide-flame.vercel.app",
    "launch:v1.2:smoke": "node scripts/smoke-production.mjs https://ai-ide-flame.vercel.app && node scripts/smoke-report.mjs https://ai-ide-flame.vercel.app",
    "go-live:preflight": "npm run test:local && npm run smoke:report",
    "rc:live-spotcheck": "node scripts/rc-live-spotcheck.mjs",
    "mcp:smoke": "node scripts/mcp-smoke.mjs",
    "governance:report": "node scripts/governance-report.mjs",
    "ops:verify-p1": "node scripts/ops-verify-p1.mjs",
    "deploy:check": "node scripts/deploy-check.mjs",
    "p0:gate": "npm run test:local && npm run test:integration:local && node scripts/security-baseline.mjs",
    "mlp:preflight": "npm run p0:gate && npm run build && npm run test:smoke",
    "deploy:verify": "npm run check:release",
    "auth:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"",
    "admin:lookup": "tsx scripts/admin-lookup.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:setup": "npm run db:up && npm run db:push && npm run db:seed",
    "db:seed": "tsx scripts/seed-plans.ts",
    "db:check": "node scripts/check-db.mjs",
    "wait:web": "node scripts/wait-for-http.mjs http://127.0.0.1:3000",
    "electron:start": "node scripts/electron-launch.mjs",
    "electron:dev": "concurrently -k -n web,wait,electron -c green,yellow,blue \"npm run dev\" \"npm run wait:web\" \"npm run electron:start\"",
    "build:electron": "vite build --mode electron",
    "electron:pack": "node scripts/electron-pack.mjs",
    "electron:pack:installer": "node scripts/electron-builder-run.mjs --win nsis --publish never",
    "electron:pack:mac": "node scripts/electron-builder-run.mjs --mac dmg zip --publish never",
    "electron:pack:offline": "npm run build:electron && node scripts/electron-builder-run.mjs --win portable --publish never",
    "electron:publish": "node scripts/electron-publish.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^2.11.2",
    "@monaco-editor/react": "^4.6.0",
    "@neondatabase/serverless": "^0.10.4",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jszip": "^3.4.0",
    "@webcontainer/api": "^1.6.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "alipay-sdk": "^4.14.0",
    "bcryptjs": "^3.0.3",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.3.0",
    "idb": "^8.0.3",
    "isomorphic-git": "^1.37.5",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "livekit-client": "^2.19.1",
    "livekit-server-sdk": "^2.15.4",
    "lucide-react": "^0.294.0",
    "monaco-editor": "^0.45.0",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^17.7.0",
    "uuid": "^14.0.0",
    "wechatpay-node-v3": "^2.2.1",
    "ws": "^8.18.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.12",
    "fake-indexeddb": "^6.2.5",
    "prisma": "^6.6.0",
    "tsx": "^4.22.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@sentry/react": "^8.55.2",
    "node-pty": "^1.0.0"
  }
}
