# Copy to .env.local — Neon (no Docker required)
# Get DATABASE_URL from https://console.neon.tech → your project → Connect
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
AUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""

# --- Optional: Docker local Postgres instead of Neon ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_ide?schema=public"

# Frontend-only: allow localStorage fake login when API is down (dev default: on via import.meta.env.DEV)
# VITE_ALLOW_OFFLINE_AUTH="true"

# OAuth — GitHub / Google (Gmail). See docs/OAUTH_SETUP.md
# VITE_ENABLE_OAUTH="true"
# AUTH_URL="http://localhost:3000"
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
