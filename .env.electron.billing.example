# Optional override — desktop billing is now default in .env.electron (VITE_PUBLIC_WELFARE=false).
# Use this file only for staging API or A/B tests. Smoke: npm run smoke:desktop-billing

VITE_API_BASE_URL=https://your-api.example.com
VITE_PUBLIC_WELFARE=false
VITE_GA_LIVE=true

