# =============================================================================
# AI IDE — 阿里云生产环境（复制到服务器 /opt/ai-ide/.env.production）
# 备案前：可先填 DATABASE_URL + AUTH_SECRET，用内网 IP 调试 API
# 备案后：务必设置 APP_URL=https://你的已备案域名
# 前端 VITE_* 构建变量见仓库根目录 .env.production.example
# 完整说明：docs/ENV_PRODUCTION.md · P0：docs/CN_LAUNCH_P0.md
# =============================================================================

NODE_ENV=production
API_PORT=3001

# [推荐] /api/health 版本号（默认读 package.json）
APP_VERSION=1.7.0

# [必填] 阿里云 RDS PostgreSQL（不要用 Neon 美区）
# 控制台 → RDS → 连接地址，建议内网地址 + 白名单仅 ECS 安全组
DATABASE_URL="postgresql://ai_ide:CHANGE_ME@pgm-xxx.pg.rds.aliyuncs.com:5432/ai_ide?sslmode=disable"

# [必填] openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"

# [备案通过后必填] 对外 HTTPS 域名（不要带末尾 /）
APP_URL="https://example.com"
AUTH_URL="https://example.com"

# [推荐] 国内正式运营保持 false（开启 Pro ¥39 / Team ¥79）
PUBLIC_WELFARE_MODE=false

# [阿里云必填] crontab 调 expire-subscriptions / jobs/process 时使用
# openssl rand -base64 32
CRON_SECRET=""
BILLING_CRON_SECRET=""

# [国内平台 AI] 构建前端时需 VITE_AI_GATEWAY=true（.env.production.example）
PLATFORM_DEEPSEEK_API_KEY=""
PLATFORM_AI_PROVIDER="deepseek"

# [收费必填] 支付宝 — 需个体户/企业商户 + 备案域名
# 回调 URL：APP_URL=https://域名 node scripts/payment-notify-urls.mjs
# ALIPAY_APP_ID=""
# ALIPAY_PRIVATE_KEY=""
# ALIPAY_PUBLIC_KEY=""
# PAYMENT_NOTIFY_URL="https://example.com/api/payment/alipay/notify"

# [可选] 微信支付
# WECHAT_APP_ID=""
# WECHAT_MCH_ID=""
# WECHAT_API_V3_KEY=""

# [可选] 前端 Sentry — 构建时在 .env.production 设置 VITE_SENTRY_DSN
# VITE_SENTRY_DSN="https://...@sentry.io/..."

# [可选] 邮件 — 建议阿里云邮件推送 SMTP
# AUTH_EMAIL_SERVER="smtp://..."
# AUTH_EMAIL_FROM="noreply@example.com"

# [可选] OAuth 国内体验一般，可暂不配
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# [可选] 桌面客户端构建（开发机 .env.electron）
# VITE_API_BASE_URL="https://example.com"
