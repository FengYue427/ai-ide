# =============================================================================
# AI IDE — Environment variables
# Copy to `.env.local` for local `vercel dev`, or set in Vercel Project Settings.
# Legend: [REQUIRED] | [OPTIONAL] | [ROUTE-SPECIFIC]
# =============================================================================

# -----------------------------------------------------------------------------
# Database — used by auth + (future) workspaces cloud sync
# Routes: POST /api/auth/register, GET /api/auth/session, ...
# -----------------------------------------------------------------------------
# [REQUIRED for cloud auth] PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# -----------------------------------------------------------------------------
# Auth / JWT — session cookies and token signing
# Routes: all /api/auth/*, JWT verification on protected routes
# -----------------------------------------------------------------------------
# [REQUIRED in production] openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# [RECOMMENDED for OAuth] Public URL (callbacks) — same as APP_URL in production
# AUTH_URL="http://localhost:3000"

# [OPTIONAL] OAuth — GitHub / Google (Gmail). Routes: /api/auth/oauth/*
# Also set VITE_ENABLE_OAUTH=true in .env.local for login buttons
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# -----------------------------------------------------------------------------
# Email — password reset
# Route: POST /api/auth/forgot-password
# -----------------------------------------------------------------------------
# [OPTIONAL] SMTP URL (Nodemailer) — required for real password-reset emails
AUTH_EMAIL_SERVER="smtp://username:password@smtp.resend.com:587"
AUTH_EMAIL_FROM="noreply@yourdomain.com"

# [OPTIONAL] Resend API (if using Resend instead of SMTP)
RESEND_API_KEY="your-resend-api-key"

# [OPTIONAL] Show "Forgot password" in login UI (requires AUTH_EMAIL_SERVER on server)
# VITE_ENABLE_PASSWORD_RESET="true"

# -----------------------------------------------------------------------------
# Subscriptions — 支付宝 / 微信（国内，推荐）
# POST /api/subscription/checkout  body: { planId, channel: "alipay"|"wechat" }
# POST /api/payment/alipay/notify  POST /api/payment/wechat/notify
# -----------------------------------------------------------------------------
# APP_URL="http://localhost:3000"
# 本地异步通知（支付宝/微信回调）需公网 HTTPS，例如 ngrok：
# PAYMENT_NOTIFY_URL="https://xxxx.ngrok-free.app"
#
# 支付宝 — 沙箱: ALIPAY_SANDBOX=true（自动用沙箱网关）
# ALIPAY_APP_ID=""
# ALIPAY_PRIVATE_KEY=""          # 或 ALIPAY_PRIVATE_KEY_PATH=
# ALIPAY_PUBLIC_KEY=""           # 或 ALIPAY_PUBLIC_KEY_PATH=
# ALIPAY_SANDBOX="true"
# ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"
#
# 微信支付 — 商户私钥 + 平台证书公钥（非同一文件）
# WECHAT_APP_ID=""
# WECHAT_MCH_ID=""
# WECHAT_API_V3_KEY=""
# WECHAT_SERIAL_NO=""
# WECHAT_PRIVATE_KEY=""          # 或 WECHAT_PRIVATE_KEY_PATH=
# WECHAT_PLATFORM_PUBLIC_KEY=""  # 或 WECHAT_PLATFORM_PUBLIC_KEY_PATH=

# -----------------------------------------------------------------------------
# Subscriptions / Stripe（可选，海外）
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# STRIPE_PRICE_ENTERPRISE="price_..."
# ALLOW_DEV_BILLING="true"       # 生产禁止
# BILLING_CRON_SECRET="..."    # D3 GA: Vercel cron → /api/billing/expire-subscriptions (or use CRON_SECRET)

# -----------------------------------------------------------------------------
# Usage API — server-side AI daily quota (UsageRecord table)
# Routes: GET/POST /api/usage/ai
# -----------------------------------------------------------------------------
# Logged-in users sync quota to Postgres; guests use browser localStorage only.

# -----------------------------------------------------------------------------
# Frontend-only (no server env)
# -----------------------------------------------------------------------------
# AI provider API keys are entered in the IDE UI and stored in the browser.
# WebContainer requires COOP/COEP headers (configured in vite.config.ts / vercel.json).

# [OPTIONAL] Sentry DSN — npm install @sentry/react; auto-wired when set (see docs/OBSERVABILITY.md)
# VITE_SENTRY_DSN="https://...@sentry.io/..."

# [GA] Set on Vercel Production when D3 billing is live — welcome badge shows 正式版 / GA
# VITE_GA_LIVE="true"

# [v1.1.2] Background Agent — UI + client API calls (default off until GA)
# VITE_BACKGROUND_AGENT="false"
#
# Worker (F2): Cron GET|POST /api/jobs/process — same Bearer as billing cron (CRON_SECRET / BILLING_CRON_SECRET)
# BACKGROUND_JOB_WORKER_MODE="dummy"   # dummy (default) | agent (cloud workspace + LLM)
# BACKGROUND_AGENT_API_KEY=""          # required when WORKER_MODE=agent (platform key, not browser storage)
# BACKGROUND_AGENT_PROVIDER="deepseek" # openai | deepseek | grok | zhipu | minimax
# BACKGROUND_AGENT_MODEL=""            # optional; workspace settings aiModel can override
# BACKGROUND_AGENT_MAX_ROUNDS="8"
