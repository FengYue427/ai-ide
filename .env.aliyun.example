# 阿里云部署配置（复制为 .env.aliyun — 勿提交 Git）
# cp .env.aliyun.example .env.aliyun

# SSH：用户@ECS公网IP 或 备案后的域名跳板
ALIYUN_SSH=ubuntu@47.xxx.xxx.xxx
ALIYUN_DEPLOY_PATH=/opt/ai-ide

# 备案通过后的对外域名（用于 smoke / nginx 渲染 / 支付回调）
APP_URL=https://your-domain.com

# 迁库 Neon → RDS（npm run db:migrate:neon-to-rds）
SOURCE_DATABASE_URL=postgresql://neondb_owner:****@ep-xxx.neon.tech/neondb?sslmode=require
TARGET_DATABASE_URL=postgresql://ai_ide:****@pgm-xxx.pg.rds.aliyuncs.com:5432/ai_ide?sslmode=disable

# 服务器 API 环境（也可单独 scp 到 /opt/ai-ide/.env.production）
# 见 deploy/aliyun/env.production.example
