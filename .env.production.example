# v1.7+ — Vite production build defaults (Vercel Production + 阿里云构建机).
# Copy to .env.production: cp .env.production.example .env.production
# See docs/ENV_PRODUCTION.md · 阿里云 P0: docs/CN_LAUNCH_P0.md

VITE_AI_GATEWAY=true
VITE_ALLOW_BYOK_LEGACY=false
VITE_TAB_PLUS_PLUS=true
VITE_AIDE_SPEC_ARTIFACTS_V2=true
VITE_AIDE_RUNTIME=true
VITE_AIDE_RUNTIME_UI=true
VITE_AIDE_ACTIVITY_LINE=true

# GA badge on welcome screen when billing is live
VITE_GA_LIVE=true

# Optional — frontend error reporting (see docs/OBSERVABILITY.md)
# VITE_SENTRY_DSN="https://...@sentry.io/..."

# 备案通过后填入（npm run aliyun:post-beian -- --icp=鲁ICP备xxxxxxxx号）
# VITE_ICP_BEIAN="鲁ICP备xxxxxxxx号"

# 可选 — 桌面便携版下载地址（默认 /downloads/AI-IDE-{version}-win-portable.exe）
# VITE_DESKTOP_DOWNLOAD_URL="/downloads/AI-IDE-1.7.0-win-portable.exe"
